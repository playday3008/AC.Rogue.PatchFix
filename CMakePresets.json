{
    "version": 6,
    "configurePresets": [
        {
            "name": "linux-x64-release",
            "displayName": "Linux x64 Release",
            "generator": "Ninja",
            "toolchainFile": "${sourceDir}/cmake/toolchains/msvc-wine-clang-cl-x64.cmake",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "linux-x64-debug",
            "displayName": "Linux x64 Debug",
            "generator": "Ninja",
            "toolchainFile": "${sourceDir}/cmake/toolchains/msvc-wine-clang-cl-x64.cmake",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "windows-x64-release",
            "displayName": "Windows x64 Release",
            "generator": "Visual Studio 18 2026",
            "architecture": "x64",
            "toolset": "ClangCL",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "windows-x64-debug",
            "displayName": "Windows x64 Debug",
            "generator": "Visual Studio 18 2026",
            "architecture": "x64",
            "toolset": "ClangCL",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "linux-x64-release",
            "configurePreset": "linux-x64-release"
        },
        {
            "name": "linux-x64-debug",
            "configurePreset": "linux-x64-debug"
        },
        {
            "name": "windows-x64-release",
            "configurePreset": "windows-x64-release"
        },
        {
            "name": "windows-x64-debug",
            "configurePreset": "windows-x64-debug"
        }
    ]
}
